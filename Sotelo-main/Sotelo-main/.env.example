# ── Docker / BD local ───────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpass
DB_DATABASE=sotelo_payroll
DB_USERNAME=sotelo
DB_PASSWORD=sotelopass
DB_PORT=3306
ADMINER_PORT=8080

# ── Backend CI4 ─────────────────────────────────────────────────────
# Copiar backend/env → backend/.env y ajustar con estos valores
CI_ENVIRONMENT=development
DB_HOST=127.0.0.1
# DB_DATABASE, DB_USERNAME, DB_PASSWORD — mismos que Docker arriba

# ── Auth JWT ─────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-32-chars
ADMIN_EMAIL=admin@sotelo.local
ADMIN_PASSWORD=cambia-esta-password

# ── Frontend Vite ────────────────────────────────────────────────────
# En frontend/.env:
VITE_API_BASE_URL=http://localhost:8080
