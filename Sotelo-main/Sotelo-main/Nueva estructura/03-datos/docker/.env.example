# Copia este archivo a .env (NO lo subas al repo) y ajusta valores.
# Estos valores son SOLO para la BD de prueba con Docker.

# --- MySQL (Docker) ---
DB_ROOT_PASSWORD=rootpass
DB_DATABASE=sotelo_payroll
DB_USERNAME=sotelo
DB_PASSWORD=sotelopass
DB_PORT=3306
ADMINER_PORT=8080

# --- CodeIgniter 4 (backend/.env) — referencia de mapeo ---
# database.default.hostname = 127.0.0.1
# database.default.database = sotelo_payroll
# database.default.username = sotelo
# database.default.password = sotelopass
# database.default.DBDriver = MySQLi
# database.default.port     = 3306

# --- Producción (Fase 5) ---
# NO almacenar credenciales productivas en el repositorio.
# Inyectar por variables de entorno del servidor / secret manager:
# PROD_DB_HOST=nomina-sotelo.dataholics.com.mx
# PROD_DB_NAME=...
# PROD_DB_USER=...
# PROD_DB_PASS=...   <-- secret, fuera de control de versiones
